[OPTIONS]

policy_in: DROP
enable: 1
log_level_in: nolog

[RULES]

IN ACCEPT -source dc/vm-public-ingress -p tcp -dport 8001 -log nolog # etebase
IN ACCEPT -source dc/vm-public-ingress -p tcp -dport 8222 -log nolog # vaultwarden
IN ACCEPT -source dc/vm-public-ingress -p tcp -dport 8083 -log nolog # owntracks
IN ACCEPT -source dc/vm-public-ingress -p tcp -dport 1883 -log nolog # mosquitto

GROUP gp-vm
